class Solution {
    public boolean canJump(int[] nums) {
        int maxIdx = 0;

        for( int i = 0; i < nums.length ; i++){
            if(i > maxIdx){
                return false;
            }

            int Num = nums[i] + i ;
            maxIdx = Math.max(maxIdx, Num);
        }
        return true;
    }
}