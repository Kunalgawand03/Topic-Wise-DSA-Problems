class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];

        int totsum = 0;
        for(int i = 0 ; i < n; i++){
            totsum+= nums[i];
        }

        int leftSum = 0;
        for (int i = 0; i < n; i++) {
            int rightSum = totsum - leftSum - nums[i];
            ans[i] = Math.abs(leftSum - rightSum);
            leftSum += nums[i];
        }
        
        return ans;
    }
}
